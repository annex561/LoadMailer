# ============================================================
# TRAQ-IQ Environment Variables
# Copy this file to .env and fill in your values.
# Set all of these in Railway's "Variables" tab.
# ============================================================

# ── Core ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-random-secret

# ── Database (Neon PostgreSQL) ───────────────────────────────
# Get from https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Twilio (SMS) ─────────────────────────────────────────────
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Update this to your Railway app URL after deploying
TWILIO_WEBHOOK_URL=https://your-app.railway.app/api/sms/webhook

# ── OpenAI ───────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Google / Gmail ───────────────────────────────────────────
# For BOL email ingestion - set up OAuth at https://console.cloud.google.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# ── DAT Load Board ───────────────────────────────────────────
DAT_API_KEY=
DAT_CLIENT_ID=
DAT_EMAIL=
DAT_PASSWORD=

# ── Stripe (Billing) ─────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Telegram (Optional notifications) ────────────────────────
TELEGRAM_BOT_TOKEN=
DISPATCHER_TELEGRAM_ID=
DISPATCHER_CHAT_ID=

# ── Company Info ─────────────────────────────────────────────
COMPANY_EMAIL=
COMPANY_PHONE=
DOT_NUMBER=
MC_NUMBER=
DISPATCHER_PHONE_NUMBER=

# ── App URLs ─────────────────────────────────────────────────
# Set after Railway gives you a URL, and after you connect traqiqs.io
BASE_URL=https://traqiqs.io
API_BASE_URL=https://traqiqs.io

# ── Email (SMTP - optional if using Gmail OAuth above) ───────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Admin ────────────────────────────────────────────────────
ADMIN_API_KEY=replace-with-random-string
