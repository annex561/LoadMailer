modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["chromium", "glib", "nspr", "nss", "dbus", "at-spi2-atk", "gtk3", "libdrm", "mesa", "alsa-lib", "atk", "gdk-pixbuf", "pango", "cairo", "libxkbcommon", "xorg.libX11", "xorg.libXext", "xorg.libXrender", "xorg.libXi", "xorg.libXtst", "fontconfig", "freetype", "jq", "ffmpeg"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 33773
externalPort = 8080

[[ports]]
localPort = 33989
externalPort = 6800

[[ports]]
localPort = 37935
externalPort = 6000

[[ports]]
localPort = 38099
externalPort = 5000

[[ports]]
localPort = 38525
externalPort = 3001

[[ports]]
localPort = 38897
externalPort = 3002

[[ports]]
localPort = 39179
externalPort = 8099

[[ports]]
localPort = 40981
externalPort = 4200

[[ports]]
localPort = 41019
externalPort = 8000

[[ports]]
localPort = 44831
externalPort = 3003

[[ports]]
localPort = 45279
externalPort = 5173

[[ports]]
localPort = 45545
externalPort = 8081

[[ports]]
localPort = 46127
externalPort = 3000

[[ports]]
localPort = 46827
externalPort = 8008

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[agent]
integrations = ["javascript_database==1.0.0", "javascript_log_in_with_replit==1.0.0", "javascript_object_storage==1.0.0"]
